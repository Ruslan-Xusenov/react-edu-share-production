{
  "expo": {
    "name": "EduShare",
    "slug": "edushare-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "edushare",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#102C26"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.edushare.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil rasmingizni yuklash uchun",
        "NSPhotoLibraryUsageDescription": "Profil rasmingizni yuklash uchun",
        "NSMicrophoneUsageDescription": "Video yozish uchun"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#102C26"
      },
      "package": "uz.edushare.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c72dadeb-d124-4164-a843-554dd5544dba"
      },
      "router": {},
      "googleExpoClientId": "156032019101-fcpg1tfle3ubau9d19p7gr51ke580e9r.apps.googleusercontent.com",
      "googleAndroidClientId": "166926794258-g76akjkg3m6lghbera5ckqbal7m4jt1u.apps.googleusercontent.com",
      "googleIosClientId": "",
      "googleWebClientId": "156032019101-fcpg1tfle3ubau9d19p7gr51ke580e9r.apps.googleusercontent.com"
    },
    "owner": "ruslan_xusenov11"
  }
}
